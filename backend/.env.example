# 复制为 .env 后填写真实值。.env 已被 .gitignore 忽略，切勿提交。

# Django 密钥（生产必须重新生成）：python -c "import secrets;print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-in-production

# 调试开关（生产为 False）
DEBUG=True

# 允许访问的主机，逗号分隔
ALLOWED_HOSTS=127.0.0.1,localhost

# 前端跨域来源，逗号分隔（开发期 Vite 端口 5179）
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5179,http://localhost:5179

# 数据源密码加密 Key（Fernet）：python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-generate-a-fernet-key

# 取数安全护栏
QUERY_MAX_ROWS=100000
QUERY_TIMEOUT_SECONDS=60
QUERY_FETCH_SIZE=1000

# 每个数据集保留最近 N 次执行/文件（超出自动清理）
EXECUTION_KEEP=20

# 平台元数据库：默认 SQLite（无需配置）。如要复用现有 MySQL，取消下行注释并填写：
# DATABASE_URL=mysql://user:password@host:3306/datanexus
